{
  "name": "cartkey",
  "version": "0.1.0",
  "description": "Program RFID cards to launch your Steam and GOG games",
  "main": "./out/main/index.js",
  "author": {
    "name": "CrissZollo",
    "email": "depth-broaden-oboe@duck.com"
  },
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/CrissZollo/CartKey.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "dist": "electron-vite build && electron-builder",
    "postinstall": "electron-rebuild -f -w @pokusew/pcsclite"
  },
  "dependencies": {
    "electron-updater": "6.8.9",
    "framer-motion": "12.42.2",
    "nfc-pcsc": "0.8.1",
    "open": "11.0.0",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@electron/rebuild": "4.2.0",
    "@tailwindcss/vite": "4.3.3",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "43.2.0",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3",
    "vite": "7.3.6"
  },
  "allowScripts": {
    "@pokusew/pcsclite@0.6.0": true,
    "electron-winstaller@5.4.0": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true
  },
  "build": {
    "appId": "com.crisszollo.cartkey",
    "productName": "CartKey",
    "directories": {
      "buildResources": "resources"
    },
    "files": [
      "!src/*",
      "!electron.vite.config.{js,ts,mjs,cjs}",
      "!{.eslintignore,.eslintrc.cjs,.prettierignore,.prettierrc.yaml,dev-app-update.yml,CHANGELOG.md,README.md}",
      "!{.env,.env.*,.npmrc,pnpm-lock.yaml}",
      "!{tsconfig.json,tsconfig.node.json,tsconfig.web.json,tsconfig.node.tsbuildinfo,tsconfig.web.tsbuildinfo}"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "CrissZollo",
        "repo": "CartKey"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "pacman"
      ],
      "category": "Game",
      "icon": "resources/icon.png",
      "synopsis": "Program RFID cards to launch your Steam and GOG games"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
